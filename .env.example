# アプリ（Expo）用。コピーして .env にリネームし、値を入れる。

# Stripe Checkout を有効化（1 のときだけ）
EXPO_PUBLIC_USE_STRIPE_CHECKOUT=1

# vercel-stripe-api デプロイ後の URL（末尾まで含める）
EXPO_PUBLIC_STRIPE_CHECKOUT_API_URL=https://あなたのプロジェクト.vercel.app/api/stripe-checkout
EXPO_PUBLIC_STRIPE_VERIFY_API_URL=https://あなたのプロジェクト.vercel.app/api/stripe-verify

# 任意: ホームのスポンサーバナー CTA の遷移先
# EXPO_PUBLIC_BANNER_EXTERNAL_URL=https://example.com
